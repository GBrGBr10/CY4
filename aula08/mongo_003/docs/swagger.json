{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "Biblioteca Digital API",
    "description": "Documentação da API da Biblioteca Digital"
  },
  "host": "localhost:3000",
  "basePath": "/api",
  "schemes": ["http"],
  "paths": {
    "/books": {
      "post": {

        "summary": "Criar um novo livro",
        "description": "Adicionar um novo livro a biblioteca digital",
        "parameters": [
          {
            "name":"body",
            "in":"body",
            "description": "Dados do livro a ser criado",
            "schema" : {
              "type": "object",
              "properties": {
                "title": {
                  "type":"string",
                  "example":"Senhor dos Anéis"
                },
                "author": {
                  "type":"string",
                  "example":"Tolkien"
                },
                "year": {
                  "type": "integrer",
                  "example": 1954
                },
                "genre": {
                  "type":"string",
                  "example": "fantasia"
                  }
                }
              }
            }
        ],
        "responses": {
          "201": {
            "description" : "Livro criado com sucesso"

          },
          "500" : {
            "description": "Erro ao criar livro"
          }
        }
      },
      "get": {
        "summary":"Lista os livros",
        "description": "Obtém uma lista de todos os livros",
        "responses": {
          "201": {
            "description": "Livros listados com sucesso",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "string", "example": "xxxxxxxxxxxxxxxxx"},
                  "title": {"type": "string", "example":"Senhor dos Anéis"},
                  "author": {"type": "string", "example":"Tolkien"},
                  "year": {"type": "integer", "example": 1954},
                  "genre": {"type": "string", "example": "Fantasia"}
                }
              }
            }
          }
        }
      }
    },
    "/books/{id}": {
      "patch": {
        "summary": "Atualizar um livro",
        "description": "Atualiza alguma propriedade do livro",
        "parameters": [ 
        {
          "name": "id",
          "in": "path",
          "description": "Id do livro a ser atualizado",
          "require": true,
          "type": "string"
        },
        {
          "name": "body",
          "in": "body",
          "description": "Dados do livro a ser atualizado",
          "required": true,
          "schema": {
            "type": "object",
              "properties": {
                "title": {"type": "string", "example":"Senhor dos Anéis"},
                "author": {"type": "string", "example":"Tolkien"},
                "year": {"type": "integer", "example": 1954},
                "genre": {"type": "string", "example": "Fantasia"}
              }
            }
          }
        ],
        "responses": {
          "200": {
          "description": "Livro atualizado com sucesso",
          "schema": {
              "type": "object",
                "properties": {
                  "title": {"type": "string", "example":"Senhor dos Anéis"},
                  "author": {"type": "string", "example":"Tolkien"},
                  "year": {"type": "integer", "example": 1954},
                  "genre": {"type": "string", "example": "Fantasia"}
                }
            }
          },
          "404": {
            "description": "Livro não encontrado"
          },
          "500":{
            "description":"Erro interno do servidor"
          }
        }
      },
      "delete": {
        "summary": "Atualizar um livro",
        "description": "Atualiza alguma propriedade do livro",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Id do livro a ser atualizado",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Livro excluído com sucesso",
            "schema": {
              "type": "object",
              "properties": {
                "message": { "type": "string", "example": "Livro excluído com sucesso"}
              }
            }
          },
          "404": {
            "description": "Livro não encontrado"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      }  
    }
  }
}

